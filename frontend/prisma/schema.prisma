// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid(2))
  email     String?  @unique
  name      String?
  password  String? // 크리덴셜 로그인용 (현재 null, 향후 사용)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts       Account[]
  tasks          Task[]
  executions     Execution[]
  plans          Plan[]
  categories     Category[]
  categoryGroups CategoryGroup[]

  @@map("users")
}

model Account {
  id                String @id @default(cuid(2))
  userId            String @map("user_id")
  provider          String // "google", "github"
  providerAccountId String @map("provider_account_id") // OAuth sub
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Task {
  id             Int      @id @default(autoincrement())
  title          String   @db.VarChar(255)
  completed      Boolean  @default(false)
  startTimestamp DateTime @map("start_timestamp")
  endTimestamp   DateTime @map("end_timestamp")
  isAllDay       Boolean  @default(false) @map("is_all_day")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  planId      Int?      @map("plan_id")
  plan        Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  executionId Int?      @map("execution_id")
  execution   Execution? @relation(fields: [executionId], references: [id], onDelete: SetNull)
  categoryId  Int?      @map("category_id")
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

model Execution {
  id             Int      @id @default(autoincrement())
  startTimestamp DateTime @map("start_timestamp")
  endTimestamp   DateTime @map("end_timestamp")
  title          String   @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id])
  tasks      Task[]
  categoryId Int?      @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("executions")
}

model Plan {
  id             Int      @id @default(autoincrement())
  title          String   @db.VarChar(255)
  startTimestamp DateTime @map("start_timestamp")
  endTimestamp   DateTime @map("end_timestamp")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id])
  tasks      Task[]
  categoryId Int?      @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("plans")
}

model CategoryGroup {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  color     String   @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId     String     @map("user_id")
  user       User       @relation(fields: [userId], references: [id])
  categories Category[]

  @@map("category_groups")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  color     String   @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId          String         @map("user_id")
  user            User           @relation(fields: [userId], references: [id])
  categoryGroupId Int?           @map("category_group_id")
  categoryGroup   CategoryGroup? @relation(fields: [categoryGroupId], references: [id], onDelete: SetNull)
  tasks           Task[]
  executions      Execution[]
  plans           Plan[]

  @@map("categories")
}
